# Top-level comment
# <- comment

objectidentifier acmeRoot 1.3.6.1.4.1.99999
# <- keyword
#                ^ constant
#                         ^ constant.numeric

objectClass ( 1.2.3.4
# <- keyword
#             ^ constant.numeric
    NAME 'person'
#   ^ keyword
#        ^ type
    DESC 'An example objectclass'
#   ^ keyword
#        ^ string
    SUP top STRUCTURAL
#   ^ keyword
#       ^ type
#           ^ keyword
    MUST cn
#   ^ keyword
#        ^ constant
    MAY ( sn $ description )
#   ^ keyword
#         ^ constant
#              ^ constant
    X-ORIGIN 'RFC 1234' )
#   ^ attribute
#            ^ string

attributeType ( 1.2.3.5
# <- keyword
    NAME 'testAttr'
#        ^ type
    EQUALITY caseIgnoreMatch
#   ^ keyword
#            ^ function
    ORDERING caseIgnoreOrderingMatch
#   ^ keyword
#            ^ function
    SUBSTR caseIgnoreSubstringsMatch
#   ^ keyword
#          ^ function
    SYNTAX 1.3.6.1.4.1.1466.115.121.1.15{32}
#   ^ keyword
#          ^ constant.numeric
#                                        ^ constant.numeric
    SINGLE-VALUE
#   ^ keyword
    NO-USER-MODIFICATION
#   ^ keyword
    USAGE directoryOperation )
#   ^ keyword
#         ^ keyword
