{
	"name": "tree-sitter-ldap-schema",
	"version": "0.1.0",
	"description": "Tree-sitter grammar for OpenLDAP / RFC 4512 LDAP schema files",
	"keywords": [
		"parser",
		"tree-sitter",
		"ldap",
		"openldap",
		"schema"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/tree-sitter-ldap-schema.git"
	},
	"license": "MIT",
	"type": "module",
	"main": "bindings/node",
	"files": [
		"grammar.js",
		"queries/*",
		"src/*",
		"bindings/node/*"
	],
	"scripts": {
		"fmt": "dprint fmt",
		"generate": "tree-sitter generate",
		"parse": "tree-sitter parse",
		"test": "tree-sitter test",
		"build:wasm": "tree-sitter build --wasm",
		"playground": "[[ -n tree-sitter-ldap_schema.wasm ]] && bun build:wasm; tree-sitter playground --quiet --grammar-path ."
	},
	"devDependencies": {
		"dprint": "^0.53.0",
		"tree-sitter-cli": "^0.25.3",
		"typescript": "^5.9.3"
	},
	"tree-sitter": [
		{
			"scope": "source.ldap-schema",
			"file-types": [
				"schema",
				"ldif-schema",
				"ldap-schema"
			],
			"highlights": "queries/highlights.scm"
		}
	],
	"packageManager": "bun@1.3.11"
}
