{
	"grammars": [
		{
			"name": "ldap_schema",
			"scope": "source.ldap-schema",
			"path": ".",
			"file-types": ["schema", "ldapschema"],
			"first-line-regex": "^#.*(?i:openldap|ldap|schema|attributetype|objectclass)",
			"content-regex": "(?i:attributetype|objectclass|objectidentifier)\\s",
			"injection-regex": "^ldap[-_]?schema$",
			"highlights": "queries/highlights.scm",
			"tags": "queries/tags.scm",
			"locals": "queries/locals.scm"
		}
	],
	"metadata": {
		"version": "0.1.0",
		"license": "MIT",
		"description": "Tree-sitter grammar for OpenLDAP / RFC 4512 LDAP schema files",
		"authors": [
			{
				"name": "Kaj Kowalski",
				"email": "info@kajkowalski.nl"
			}
		],
		"links": {
			"repository": "https://github.com/kjanat/tree-sitter-ldap-schema"
		}
	},
	"bindings": {
		"c": true,
		"node": true,
		"rust": true
	}
}
